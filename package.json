{
  "name": "ieltsy",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "IELTS Band 7 learning webapp",
  "scripts": {
    "db:init": "tsx scripts/init-db.ts",
    "db:import:topics": "tsx scripts/import-topics.ts",
    "db:import:oxford": "tsx scripts/import-oxford.ts",
    "db:import:awl": "tsx scripts/import-awl.ts",
    "db:import:grammar": "tsx scripts/import-grammar.ts",
    "db:import:all": "pnpm db:import:topics && pnpm db:import:oxford && pnpm db:import:awl && pnpm db:import:grammar",
    "db:stats": "tsx scripts/query-stats.ts",
    "db:reset": "rm -f db/ieltsy.db db/ieltsy.db-shm db/ieltsy.db-wal && pnpm db:init && pnpm db:import:all && pnpm db:stats",
    "study:init": "tsx scripts/study/init.ts",
    "study:today": "tsx scripts/study/today.ts",
    "study:record": "tsx scripts/study/record.ts",
    "study:render-mistakes": "tsx scripts/study/render-mistakes.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
